--- docker-compose.env.example
+++ docker-compose.env.example
@@ -16,7 +16,8 @@ MINIO_ROOT_USER=minioadmin
 MINIO_ROOT_PASSWORD=CHANGE_ME
 
 # minio（Tailchat 应用连接用）
-MINIO_URL=`http://minio:9000`
+# 注意：这里必须是 host:port（不要写 http://），否则后端会解析错误并导致 service-core 反复重启
+MINIO_URL=minio:9000
 MINIO_USER=minioadmin
 MINIO_PASS=CHANGE_ME
 MINIO_BUCKET_NAME=tailchat
@@ -24,4 +25,4 @@ MINIO_BUCKET_NAME=tailchat
 # livekit（如启用）
 LIVEKIT_URL=`http://livekit:7880`
 LIVEKIT_PUBLIC_URL=wss://chat.example.com/livekit
-LIVEKIT_KEYS=CHANGE_ME_KEY:CHANGE_ME_SECRET_32CHARS_MIN+LIVEKIT_KEYS=CHANGE_ME_KEY:CHANGE_ME_SECRET_32CHARS_MIN
