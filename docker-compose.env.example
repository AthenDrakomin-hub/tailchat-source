# 基础
API_URL=https://chat.example.com
SECRET=CHANGE_ME_LONG_RANDOM

# Node.js 内存（4GB 机器建议 1536~2048；留给 Mongo/Redis/MinIO/Traefik）
# 仅影响 Node 服务容器（core/openapi/plugins/admin）
NODE_OPTIONS=--max-old-space-size=1536

# admin
ADMIN_USER=admin
ADMIN_PASS=CHANGE_ME

# minio
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME

# minio（Tailchat 应用连接用）
# 注意：这里必须是 host:port（不要写 http://），否则后端会解析错误并导致 service-core 反复重启
MINIO_URL=minio:9000
MINIO_USER=minioadmin
MINIO_PASS=CHANGE_ME
MINIO_BUCKET_NAME=tailchat

# redis（必填）
REDIS_URL=redis://redis:6379

# livekit（如启用）
# LIVEKIT_KEYS：给 LiveKit 服务本身（livekit-server）使用
# LIVEKIT_API_KEY / LIVEKIT_API_SECRET：给 Tailchat 的 LiveKit 插件后端使用
# 三者必须保持一致（LIVEKIT_KEYS = LIVEKIT_API_KEY:LIVEKIT_API_SECRET）
LIVEKIT_URL=http://livekit:7880
LIVEKIT_PUBLIC_URL=wss://goodspage.cn/livekit
LIVEKIT_KEYS=your_key:your_secret
LIVEKIT_API_KEY=your_key
LIVEKIT_API_SECRET=your_secret

# ----------------------------
# 生产加固（建议启用）
# ----------------------------

# PWA / 离线缓存（可选）
# - 出现缓存/更新异常时可紧急禁用（需要重新构建镜像后生效）
DISABLE_SERVICE_WORKER=true

# Traefik：仅信任你自己的反代转发头（逗号分隔）
# 示例：TRAEFIK_TRUSTED_PROXIES=127.0.0.1/32,10.0.0.0/8
TRAEFIK_TRUSTED_PROXIES=127.0.0.1/32

# Socket.IO CORS：生产环境建议收敛到站点域名（逗号分隔）
# 示例：SOCKETIO_CORS_ORIGINS=https://goodspage.cn
SOCKETIO_CORS_ORIGINS=https://chat.example.com

# OIDC：生产默认建议开启 PKCE（true/false）
OIDC_REQUIRE_PKCE=true

# 未捕获异常：生产默认建议退出自愈（true/false）
EXIT_ON_UNCAUGHT=true

# Defense Control：生产必须配置（用于 executor HMAC 校验）
DEFENSE_SHARED_SECRET=CHANGE_ME_LONG_RANDOM

# Ops Executor：生产必须配置（用于“系统控制台”一键启停 LiveKit）
# - 受控执行器默认监听宿主机 127.0.0.1:9110
# - Admin 容器通过 host.docker.internal 转发访问
EXECUTOR_SHARED_SECRET=CHANGE_ME_LONG_RANDOM
OPS_EXECUTOR_URL=http://172.18.0.1:9110

# 可观测性：开启 Prometheus metrics（true/false）
PROMETHEUS=false
